{
  "name": "godot-control-mcp-server",
  "version": "0.1.0",
  "description": "MCP control plane for Godot 4.6 editor mutation, LSP, runtime/debug, and guarded batch/filesystem tools",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "godot-control-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "assets",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:live": "vitest run tests/live-godot.test.ts",
    "test:live:phase3": "vitest run tests/live-phase3.test.ts",
    "test:live:phase4": "vitest run tests/live-phase4.test.ts",
    "test:live:phase6": "vitest run tests/live-phase6.test.ts",
    "test:live:phase5": "vitest run tests/live-phase5.test.ts",
    "test:eval": "npm run build && node scripts/eval-suite.mjs",
    "lint": "tsc --noEmit",
    "start": "node dist/index.js",
    "docs:generate": "npm run build && node scripts/generate-doc-index.mjs",
    "docs:check": "npm run build && node scripts/generate-doc-index.mjs --check"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "fast-xml-parser": "5.10.0",
    "tar-stream": "3.2.0",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.0.3",
    "@types/tar-stream": "3.1.4",
    "@types/ws": "8.18.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
